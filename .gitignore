# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data points which are localized to individual environments.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and shouldn't be committed
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include hcl write locks if needed, but standard practice is to ignore them if they differ by local dev machine architecture
.terraform.lock.hcl
